#!/bin/zsh

set -euo pipefail

source "${0:A:h}/_common.sh"
require_var HARBOUR_COLIM_PROFILE
require_var HARBOUR_HARNESS_PATH
require_var HARBOUR_WORKSPACE_ROOT
require_var HARBOUR_ACTIVE_AGENT

yolo_mode=false

while [[ $# -gt 0 ]]; do
  case "${1}" in
    --yolo)
      yolo_mode=true
      shift
      ;;
    *)
      echo "Unknown option: ${1}" >&2
      echo "Usage: $0 [--yolo]" >&2
      exit 2
      ;;
  esac
done

if ! colima_status; then
  printf "Harbour profile %s is not running. Start it with make provision.\n" "${HARBOUR_COLIM_PROFILE}" >&2
  exit 1
fi

case "${HARBOUR_ACTIVE_AGENT}" in
  codex)
    agent_name="Codex"
    agent_command="codex"
    instruction_file="AGENTS.md"
    ;;
  claude)
    agent_name="Claude Code"
    agent_command="claude"
    instruction_file="CLAUDE.md"
    ;;
  *)
    printf "Unsupported HARBOUR_ACTIVE_AGENT=%s. Run make provision and choose codex or claude.\n" "${HARBOUR_ACTIVE_AGENT}" >&2
    exit 1
    ;;
esac

printf "Launching %s in Harbour profile %s\n" "${agent_name}" "${HARBOUR_COLIM_PROFILE}"
cd "${HARBOUR_WORKSPACE_ROOT}"
exec colima ssh -p "${HARBOUR_COLIM_PROFILE}" -- /usr/bin/bash -lc '
set -euo pipefail

workspace_root="'"${HARBOUR_WORKSPACE_ROOT}"'"
harbour_harness_dir="'"${HARBOUR_HARNESS_PATH}"'"
yolo_mode="'"${yolo_mode}"'"
agent_name="'"${agent_name}"'"
agent_command="'"${agent_command}"'"
instruction_file="'"${instruction_file}"'"
export PATH="${HOME}/.local/bin:${PATH}"

if ! command -v "${agent_command}" >/dev/null 2>&1; then
  echo "${agent_command} is not installed in the VM. Run make provision." >&2
  exit 127
fi

if [[ ! -d "${workspace_root}" ]]; then
  echo "${workspace_root} is not visible in the VM." >&2
  echo "Check the current mount layout, stop the Colima profile, and run make provision again." >&2
  exit 127
fi

if [[ ! -f "${workspace_root}/${instruction_file}" ]]; then
  echo "${workspace_root}/${instruction_file} is missing in the VM." >&2
  echo "Run make provision." >&2
  exit 127
fi

if [[ ! -d "${harbour_harness_dir}" ]]; then
  echo "harbour-harness is not mounted in the VM at ${harbour_harness_dir}." >&2
  echo "Check the sibling harbour-harness repo, stop the Colima profile, and run make provision again." >&2
  exit 127
fi

cd "${workspace_root}"

case "${agent_command}" in
  codex)
    if [[ "${yolo_mode}" == "true" ]]; then
      args=(--dangerously-bypass-approvals-and-sandbox -C "${workspace_root}")
    else
      args=(--sandbox workspace-write -C "${workspace_root}")
    fi
    ;;
  claude)
    if [[ "${yolo_mode}" == "true" ]]; then
      args=(--dangerously-skip-permissions)
    else
      args=(--permission-mode acceptEdits)
    fi
    ;;
esac

exec "${agent_command}" "${args[@]}"
'
