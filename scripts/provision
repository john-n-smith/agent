#!/bin/zsh

set -euo pipefail

source "${0:A:h}/_common.sh"
bootstrap_harbour_env
load_harbour_env
refresh_context_files
require_var HARBOUR_COLIM_PROFILE
require_var HARBOUR_COLIM_RUNTIME
require_var HARBOUR_COLIM_VM_TYPE
require_var HARBOUR_COLIM_ARCH
require_var HARBOUR_COLIM_CPU
require_var HARBOUR_COLIM_MEMORY
require_var HARBOUR_COLIM_DISK
require_var HARBOUR_COLIM_MOUNT_TYPE
require_var HARBOUR_COLIM_FORWARD_SSH_AGENT
require_var HARBOUR_COLIM_NETWORK_ADDRESS
require_var HARBOUR_CODEX_VERSION
require_var HARBOUR_CLAUDE_CODE_VERSION

printf "Using Harbour env %s\n" "${HARBOUR_ENV}"

if [[ -z "${HARBOUR_HARNESS_PATH:-}" ]]; then
  printf "Your Harbour harness path, e.g. ~/git/my-harbour-harness: "
  read -r HARBOUR_HARNESS_PATH
  if [[ -z "${HARBOUR_HARNESS_PATH}" ]]; then
    printf "HARBOUR_HARNESS_PATH is required.\n" >&2
    exit 1
  fi
  HARBOUR_HARNESS_PATH=$(expand_home_path "${HARBOUR_HARNESS_PATH}")
fi

require_var HARBOUR_HARNESS_PATH
if [[ ! -d "${HARBOUR_HARNESS_PATH}" ]]; then
  printf "%s does not exist.\n" "${HARBOUR_HARNESS_PATH}" >&2
  exit 1
fi
printf "HARBOUR_HARNESS_PATH=%s\n" "${HARBOUR_HARNESS_PATH}"
refresh_context_files
if [[ ! -f "${REPOS_FILE}" ]]; then
  printf "%s is missing. Create it in harbour-harness.\n" "${REPOS_FILE}" >&2
  exit 1
fi

if [[ -z "${HARBOUR_WORKSPACE_ROOT:-}" ]]; then
  printf "Workspace root, e.g. ~/git: "
  read -r HARBOUR_WORKSPACE_ROOT
  if [[ -z "${HARBOUR_WORKSPACE_ROOT}" ]]; then
    printf "HARBOUR_WORKSPACE_ROOT is required.\n" >&2
    exit 1
  fi
  HARBOUR_WORKSPACE_ROOT=$(expand_home_path "${HARBOUR_WORKSPACE_ROOT}")
fi

if [[ ! -d "${HARBOUR_WORKSPACE_ROOT}" ]]; then
  printf "HARBOUR_WORKSPACE_ROOT does not exist: %s\n" "${HARBOUR_WORKSPACE_ROOT}" >&2
  exit 1
fi
printf "HARBOUR_WORKSPACE_ROOT=%s\n" "${HARBOUR_WORKSPACE_ROOT}"

previous_active_agent="${HARBOUR_ACTIVE_AGENT:-}"
default_agent="${previous_active_agent:-codex}"

if [[ -n "${previous_active_agent}" ]]; then
  printf "HARBOUR_ACTIVE_AGENT=%s\n" "${previous_active_agent}"
fi

while true; do
  printf "Select the agent to provision [codex/claude] [%s]: " "${default_agent}"
  read -r reply
  reply="${reply:l}"
  if [[ -z "${reply}" ]]; then
    selected_agent="${default_agent}"
    break
  fi
  case "${reply}" in
    codex|claude)
      selected_agent="${reply}"
      break
      ;;
    *)
      printf "Enter codex or claude.\n" >&2
      ;;
  esac
done

case "${selected_agent}" in
  codex)
    requested_version="${HARBOUR_CODEX_VERSION}"
    if [[ "${requested_version}" == "latest" ]]; then
      printf "Resolving latest Codex release for Harbour profile %s\n" "${HARBOUR_COLIM_PROFILE}"
    else
      printf "Installing Codex %s in Harbour profile %s\n" "${requested_version}" "${HARBOUR_COLIM_PROFILE}"
    fi
    ;;
  claude)
    requested_version="${HARBOUR_CLAUDE_CODE_VERSION}"
    if [[ "${requested_version}" == "latest" ]]; then
      printf "Resolving latest Claude Code release for Harbour profile %s\n" "${HARBOUR_COLIM_PROFILE}"
    else
      printf "Installing Claude Code %s in Harbour profile %s\n" "${requested_version}" "${HARBOUR_COLIM_PROFILE}"
    fi
    ;;
esac

cmd=(colima start "${HARBOUR_COLIM_PROFILE}"
  --runtime "${HARBOUR_COLIM_RUNTIME}"
  --vm-type "${HARBOUR_COLIM_VM_TYPE}"
  --arch "${HARBOUR_COLIM_ARCH}"
  --cpu "${HARBOUR_COLIM_CPU}"
  --memory "${HARBOUR_COLIM_MEMORY}"
  --disk "${HARBOUR_COLIM_DISK}"
  --mount-type "${HARBOUR_COLIM_MOUNT_TYPE}")

if bool_flag "${HARBOUR_COLIM_FORWARD_SSH_AGENT}"; then
  cmd+=(--ssh-agent)
fi

if bool_flag "${HARBOUR_COLIM_NETWORK_ADDRESS}"; then
  cmd+=(--network-address)
fi

cmd+=(--mount "${HARBOUR_HARNESS_PATH}:w")

while IFS= read -r host; do
  [[ -n "${host}" ]] || continue
  cmd+=(--mount "${host}:w")
done < <(repo_lines true)

desired_mounts=$(desired_mount_lines | sort)
current_mounts=$(current_mount_lines | sort)

if colima_status; then
  if [[ "${desired_mounts}" != "${current_mounts}" ]]; then
    printf "Configured mounts differ from the running Harbour profile %s.\n" "${HARBOUR_COLIM_PROFILE}"
    printf "\nDesired mounts:\n"
    while IFS='|' read -r host mode; do
      [[ -n "${host}" ]] || continue
      printf "  %s (%s)\n" "${host}" "${mode}"
    done <<< "${desired_mounts}"
    printf "\nCurrent mounts:\n"
    while IFS='|' read -r host mode; do
      [[ -n "${host}" ]] || continue
      printf "  %s (%s)\n" "${host}" "${mode}"
    done <<< "${current_mounts}"
    printf "\nRestart Colima now to apply mount changes? [y/N] "
    read -r reply
    if [[ ! "${reply}" =~ ^[Yy]$ ]]; then
      printf "Aborted without restarting Colima.\n" >&2
      exit 1
    fi
    colima stop -p "${HARBOUR_COLIM_PROFILE}"
    printf "Executing:\n  "
    printf "%q " "${cmd[@]}"
    printf "\n"
    "${cmd[@]}"
  else
    printf "Harbour profile %s is already running.\n" "${HARBOUR_COLIM_PROFILE}"
  fi
else
  printf "Executing:\n  "
  printf "%q " "${cmd[@]}"
  printf "\n"
  "${cmd[@]}"
fi

harbour_harness_agents="${HARBOUR_HARNESS_PATH}/AGENTS.md"
if [[ ! -f "${harbour_harness_agents}" ]]; then
  printf "%s is missing. Create it in harbour-harness before provisioning.\n" "${harbour_harness_agents}" >&2
  exit 1
fi
harbour_harness_skills_dir="${HARBOUR_HARNESS_PATH}/skills"

harbour_harness_agents_b64=$(base64 < "${harbour_harness_agents}" | tr -d '\n')
host_uid=$(id -u)
host_gid=$(id -g)

cd "${HARBOUR_WORKSPACE_ROOT}"
colima ssh -p "${HARBOUR_COLIM_PROFILE}" -- /usr/bin/bash -s -- \
  "${selected_agent}" \
  "${requested_version}" \
  "${harbour_harness_agents}" \
  "${harbour_harness_skills_dir}" \
  "${harbour_harness_agents_b64}" \
  "${host_uid}" \
  "${host_gid}" \
  "${HARBOUR_WORKSPACE_ROOT}" <<'EOF'
set -euo pipefail

selected_agent=$1
requested_version=$2
harbour_harness_agents_path=$3
harbour_harness_skills_dir=$4
harbour_harness_agents_b64=$5
host_uid=$6
host_gid=$7
workspace_root=$8

agent_bin_dir="${HOME}/.local/bin"
codex_path="${agent_bin_dir}/codex"
claude_path="${agent_bin_dir}/claude"
codex_skills_dir="${HOME}/.codex/skills"
claude_skills_dir="${HOME}/.claude/skills"
tmpdir=$(mktemp -d)
trap 'rm -rf "${tmpdir}"' EXIT

arch=$(uname -m)
case "${arch}" in
  aarch64|arm64)
    archive_name="codex-aarch64-unknown-linux-musl.tar.gz"
    binary_name="codex-aarch64-unknown-linux-musl"
    ;;
  x86_64|amd64)
    archive_name="codex-x86_64-unknown-linux-musl.tar.gz"
    binary_name="codex-x86_64-unknown-linux-musl"
    ;;
  *)
    echo "Unsupported VM architecture: ${arch}" >&2
    exit 1
    ;;
esac

mkdir -p "${agent_bin_dir}"

sync_skills() {
  local target_skills_dir=$1
  mkdir -p "${target_skills_dir}"
  if [[ -d "${harbour_harness_skills_dir}" ]]; then
    while IFS= read -r skill_dir; do
      skill_name=$(basename "${skill_dir}")
      ln -sfn "${skill_dir}" "${target_skills_dir}/${skill_name}"
    done < <(find "${harbour_harness_skills_dir}" -mindepth 1 -maxdepth 1 -type d | sort)
  fi
}

if ! command -v make >/dev/null 2>&1 || ! command -v rg >/dev/null 2>&1 || ! command -v gh >/dev/null 2>&1; then
  sudo apt-get update
  sudo apt-get install -y gh make ripgrep
fi

if [[ ! -f "${harbour_harness_agents_path}" ]]; then
  tmp_agents=$(mktemp)
  trap 'rm -rf "${tmpdir}" "${tmp_agents}"' EXIT
  printf '%s' "${harbour_harness_agents_b64}" | base64 -d > "${tmp_agents}"
  sudo install -o "${host_uid}" -g "${host_gid}" -m 0644 "${tmp_agents}" "${harbour_harness_agents_path}"
fi

case "${selected_agent}" in
  codex)
    current_version=""
    if [[ -x "${codex_path}" ]]; then
      current_version=$("${codex_path}" --version 2>/dev/null | awk '{print $2}')
    fi

    version="${requested_version}"
    if [[ "${version}" == "latest" ]]; then
      latest_url=$(curl -fsSL -o /dev/null -w '%{url_effective}' https://github.com/openai/codex/releases/latest)
      version=${latest_url##*/}
      version=${version#rust-v}
      if [[ -z "${version}" || "${version}" == "latest" ]]; then
        echo "Failed to resolve the latest Codex release version" >&2
        exit 1
      fi
    fi

    url="https://github.com/openai/codex/releases/download/rust-v${version}/${archive_name}"

    echo "Target Codex version: ${version}"
    if [[ "${current_version}" != "${version}" ]]; then
      curl -fsSL "${url}" -o "${tmpdir}/codex.tar.gz"
      tar -xzf "${tmpdir}/codex.tar.gz" -C "${tmpdir}"
      install -m 0755 "${tmpdir}/${binary_name}" "${codex_path}"
    fi

    rm -f "${claude_path}"
    sync_skills "${codex_skills_dir}"

    sudo ln -sfn "${harbour_harness_agents_path}" "${workspace_root}/AGENTS.md"
    sudo rm -f "${workspace_root}/CLAUDE.md"
    ;;
  claude)
    current_version=""
    if [[ -x "${claude_path}" ]]; then
      current_version=$("${claude_path}" --version 2>/dev/null | awk '{print $NF}' | sed 's/^v//')
    fi

    version="${requested_version}"
    echo "Target Claude Code version: ${version}"
    if [[ "${version}" == "latest" ]]; then
      curl -fsSL https://claude.ai/install.sh | bash
      version=$("${claude_path}" --version 2>/dev/null | awk '{print $NF}' | sed 's/^v//')
      if [[ -z "${version}" ]]; then
        echo "Failed to detect the installed Claude Code version" >&2
        exit 1
      fi
    elif [[ "${current_version}" != "${version}" ]]; then
      curl -fsSL https://claude.ai/install.sh | bash -s "${version}"
    fi

    rm -f "${codex_path}"
    sync_skills "${claude_skills_dir}"

    sudo ln -sfn "${harbour_harness_agents_path}" "${workspace_root}/CLAUDE.md"
    sudo rm -f "${workspace_root}/AGENTS.md"
    ;;
esac
EOF

HARBOUR_ACTIVE_AGENT="${selected_agent}"
save_env_var HARBOUR_HARNESS_PATH "${HARBOUR_HARNESS_PATH}"
save_env_var HARBOUR_WORKSPACE_ROOT "${HARBOUR_WORKSPACE_ROOT}"
save_env_var HARBOUR_ACTIVE_AGENT "${HARBOUR_ACTIVE_AGENT}"
load_harbour_env
refresh_context_files
printf "Saved Harbour env values to %s.\n" "${HARBOUR_ENV}"

case "${selected_agent}" in
  codex)
    printf "Provisioned Codex %s, linked %s/AGENTS.md, and synced custom skills.\n" "${requested_version}" "${HARBOUR_WORKSPACE_ROOT}"
    ;;
  claude)
    printf "Provisioned Claude Code %s, linked %s/CLAUDE.md, and synced custom skills.\n" "${version:-$requested_version}" "${HARBOUR_WORKSPACE_ROOT}"
    ;;
esac

printf "Run make yolo or make agent to start.\n"
