#!/bin/zsh

set -euo pipefail

source "${0:A:h}/_common.sh"
require_var COLIMA_PROFILE
require_var HARBOUR_WORKSPACE_ROOT

if ! colima_status; then
  printf "Colima profile %s is not running. Start it with make provision.\n" "${COLIMA_PROFILE}" >&2
  exit 1
fi

printf "Opening shell in Colima profile %s\n" "${COLIMA_PROFILE}"
cd "${HARBOUR_WORKSPACE_ROOT}"
exec colima ssh -p "${COLIMA_PROFILE}" -- /usr/bin/bash -lc 'cd "'"${HARBOUR_WORKSPACE_ROOT}"'" && exec /usr/bin/bash -l'
