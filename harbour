#!/usr/bin/env bash

set -euo pipefail

SOURCE_PATH=${BASH_SOURCE[0]}
while [[ -L "${SOURCE_PATH}" ]]; do
  LINK_TARGET=$(readlink "${SOURCE_PATH}")
  if [[ "${LINK_TARGET}" = /* ]]; then
    SOURCE_PATH="${LINK_TARGET}"
  else
    SOURCE_DIR=$(cd -P -- "$(dirname -- "${SOURCE_PATH}")" && pwd -P)
    SOURCE_PATH="${SOURCE_DIR}/${LINK_TARGET}"
  fi
done
SCRIPT_DIR=$(cd -P -- "$(dirname -- "${SOURCE_PATH}")" && pwd -P)

if [[ -d "${SCRIPT_DIR}/scripts" ]]; then
  PROJECT_ROOT="${SCRIPT_DIR}"
elif [[ -d "${SCRIPT_DIR}/libexec/scripts" ]]; then
  PROJECT_ROOT="${SCRIPT_DIR}/libexec"
elif [[ -d "${SCRIPT_DIR}/../libexec/scripts" ]]; then
  PROJECT_ROOT=$(cd -P -- "${SCRIPT_DIR}/../libexec" && pwd -P)
else
  printf "Could not find Harbour support files relative to %s.\n" "${SCRIPT_DIR}" >&2
  exit 1
fi

export HARBOUR_PROJECT_ROOT="${PROJECT_ROOT}"
HARBOUR_ENV="${HOME}/.config/harbour/env"

if [[ -f "${HARBOUR_ENV}" ]]; then
  # The provisioned Harbour env stores shell-safe KEY=value pairs
  source "${HARBOUR_ENV}"
fi

usage() {
  cat <<'EOF'
Usage: harbour [command]

Commands:
  provision   Provision the Harbour VM
  shell       Open a shell in the Harbour VM
  agent       Launch the provisioned agent
  yolo        Launch the provisioned agent with relaxed permissions
  help        Show this help
  version     Show the Harbour version

If HARBOUR_DEFAULT_COMMAND is set, running harbour with no command will run it.
EOF
}

command_name=${1:-}

if [[ -z "${command_name}" && -n "${HARBOUR_DEFAULT_COMMAND:-}" ]]; then
  command_name="${HARBOUR_DEFAULT_COMMAND}"
fi

case "${command_name}" in
  provision)
    shift
    exec "${PROJECT_ROOT}/scripts/provision" "$@"
    ;;
  shell)
    shift
    exec "${PROJECT_ROOT}/scripts/shell" "$@"
    ;;
  agent)
    shift
    exec "${PROJECT_ROOT}/scripts/agent" "$@"
    ;;
  yolo)
    shift
    exec "${PROJECT_ROOT}/scripts/agent" --yolo "$@"
    ;;
  help)
    usage
    ;;
  version)
    printf "harbour %s\n" "${HARBOUR_VERSION:-dev}"
    ;;
  "")
    usage >&2
    exit 1
    ;;
  *)
    if [[ -n "${HARBOUR_DEFAULT_COMMAND:-}" && "${command_name}" == "${HARBOUR_DEFAULT_COMMAND}" ]]; then
      printf "Unsupported HARBOUR_DEFAULT_COMMAND=%s in %s.\n\n" "${HARBOUR_DEFAULT_COMMAND}" "${HARBOUR_ENV}" >&2
    else
      printf "Unknown command: %s\n\n" "${command_name}" >&2
    fi
    usage >&2
    exit 2
    ;;
esac
