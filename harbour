#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR=$(cd -P -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd -P)

if [[ -d "${SCRIPT_DIR}/scripts" ]]; then
  PROJECT_ROOT="${SCRIPT_DIR}"
elif [[ -d "${SCRIPT_DIR}/libexec/scripts" ]]; then
  PROJECT_ROOT="${SCRIPT_DIR}/libexec"
elif [[ -d "${SCRIPT_DIR}/../libexec/scripts" ]]; then
  PROJECT_ROOT=$(cd -P -- "${SCRIPT_DIR}/../libexec" && pwd -P)
else
  printf "Could not find Harbour support files relative to %s.\n" "${SCRIPT_DIR}" >&2
  exit 1
fi

export HARBOUR_PROJECT_ROOT="${PROJECT_ROOT}"

usage() {
  cat <<'EOF'
Usage: harbour <command>

Commands:
  provision   Provision the Harbour VM
  shell       Open a shell in the Harbour VM
  agent       Launch the provisioned agent
  yolo        Launch the provisioned agent with relaxed permissions
  help        Show this help
  version     Show the Harbour version
EOF
}

command_name=${1:-}

case "${command_name}" in
  provision)
    shift
    exec "${PROJECT_ROOT}/scripts/provision" "$@"
    ;;
  shell)
    shift
    exec "${PROJECT_ROOT}/scripts/shell" "$@"
    ;;
  agent)
    shift
    exec "${PROJECT_ROOT}/scripts/agent" "$@"
    ;;
  yolo)
    shift
    exec "${PROJECT_ROOT}/scripts/agent" --yolo "$@"
    ;;
  help)
    usage
    ;;
  version)
    printf "harbour %s\n" "${HARBOUR_VERSION:-dev}"
    ;;
  "")
    usage >&2
    exit 1
    ;;
  *)
    printf "Unknown command: %s\n\n" "${command_name}" >&2
    usage >&2
    exit 2
    ;;
esac
